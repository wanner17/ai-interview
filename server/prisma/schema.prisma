generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  userId       String    @id @map("user_id") @db.Char(36)
  loginId      String    @unique @map("login_id") @db.VarChar(50)
  email        String    @unique @db.VarChar(191)
  passwordHash String    @map("password_hash") @db.Text
  nickname     String    @unique @db.VarChar(50)
  userName     String?   @map("user_name") @db.VarChar(191)
  tokens       Int       @default(0)
  userRole     String    @map("user_role") @db.VarChar(20)
  userStatus   String    @map("user_status") @db.VarChar(20)
  lastLoginAt  DateTime? @map("last_login_at") @db.DateTime(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  videos       Video[]   @relation("SellerVideos")
  purchases    Purchase[]

  @@map("User")
}

model Video {
  id           String     @id @default(cuid())
  title        String
  category     String
  videoUrl     String     @db.Text
  price        Int        @default(0)
  sellerId     String     @db.VarChar(36)
  seller       User       @relation("SellerVideos", fields: [sellerId], references: [userId])
  purchases    Purchase[]
  feedbackData Json?      @map("feedback_data")
  createdAt    DateTime   @default(now())

  @@map("Video")
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String   @db.VarChar(36)
  videoId   String
  user      User     @relation(fields: [userId], references: [userId])
  video     Video    @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@map("Purchase")
}
