generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  userId       String    @id @map("user_id") @db.Char(36)
  loginId      String    @unique @map("login_id") @db.VarChar(50)
  email        String    @unique @db.VarChar(191)
  passwordHash String    @map("password_hash") @db.Text
  nickname     String    @unique @db.VarChar(50)
  userName     String?   @map("user_name") @db.VarChar(191)
  tokens       Int       @default(0)
  userRole     String    @map("user_role") @db.VarChar(20)
  userStatus   String    @map("user_status") @db.VarChar(20)
  lastLoginAt  DateTime? @map("last_login_at") @db.DateTime(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  videos       Video[]   @relation("SellerVideos")
  purchases    Purchase[]
  paymentOrders      PaymentOrder[]
  tokenTransactions  TokenTransaction[]
  @@map("User")
}

model Video {
  id           String     @id @default(cuid())
  title        String
  description  String?    @db.Text
  hashtags     String?    @db.VarChar(500)
  category     String
  videoUrl     String     @db.Text
  price        Int        @default(0)
  isListed     Boolean    @default(false) @map("is_listed")
  blurMode     String     @default("none") @map("blur_mode") @db.VarChar(20)
  voicePitch   String     @default("normal") @map("voice_pitch") @db.VarChar(20)
  sellerId     String     @db.Char(36)
  seller       User       @relation("SellerVideos", fields: [sellerId], references: [userId])
  purchases    Purchase[]
  feedbackData Json?      @map("feedback_data")
  createdAt    DateTime   @default(now())

  @@map("Video")
}

model Purchase {
  id          String   @id @default(cuid())
  userId      String   @db.Char(36)
  videoId     String
  pricePaid   Int      @default(0) @map("price_paid")
  platformFee Int      @default(0) @map("platform_fee")
  blurMode    String   @default("none") @map("blur_mode") @db.VarChar(20)
  voicePitch  String   @default("normal") @map("voice_pitch") @db.VarChar(20)
  user        User     @relation(fields: [userId], references: [userId])
  video       Video    @relation(fields: [videoId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([userId, videoId])
  @@map("Purchase")
}

model PaymentOrder {
  paymentOrderId   String    @id @default(uuid()) @map("payment_order_id") @db.Char(36)
  orderId          String    @unique @map("order_id") @db.VarChar(64)
  userId           String    @map("user_id") @db.Char(36)
  provider         String    @db.VarChar(30)
  orderType        String    @map("order_type") @db.VarChar(30)
  status           String    @db.VarChar(30)
  orderName        String    @map("order_name") @db.VarChar(191)
  amountKrw        Int       @map("amount_krw")
  tokenAmount      Int       @map("token_amount")
  paymentKey       String?   @unique @map("payment_key") @db.VarChar(200)
  method           String?   @db.VarChar(50)
  approvedAt       DateTime? @map("approved_at") @db.DateTime(3)
  requestedAt      DateTime  @default(now()) @map("requested_at") @db.DateTime(3)
  failedAt         DateTime? @map("failed_at") @db.DateTime(3)
  canceledAt       DateTime? @map("canceled_at") @db.DateTime(3)
  failureCode      String?   @map("failure_code") @db.VarChar(100)
  failureMessage   String?   @map("failure_message") @db.VarChar(500)
  lastWebhookEvent String?   @map("last_webhook_event") @db.VarChar(100)
  rawPayload       Json?     @map("raw_payload")
  createdAt        DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.DateTime(3)

  user User @relation(fields: [userId], references: [userId])
  tokenTransactions TokenTransaction[]

  @@index([userId, status])
  @@map("PaymentOrder")
}

model TokenTransaction {
  tokenTransactionId String   @id @default(uuid()) @map("token_transaction_id") @db.Char(36)
  userId             String   @map("user_id") @db.Char(36)
  paymentOrderId     String?  @map("payment_order_id") @db.Char(36)
  transactionType    String   @map("transaction_type") @db.VarChar(30)
  amount             Int
  balanceAfter       Int      @map("balance_after")
  description        String?  @db.VarChar(191)
  createdAt          DateTime @default(now()) @map("created_at") @db.DateTime(3)

  user User @relation(fields: [userId], references: [userId])
  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [paymentOrderId])

  @@index([userId, createdAt])
  @@map("TokenTransaction")
}
